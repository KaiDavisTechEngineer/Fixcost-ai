{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fixcost.ai/benchmarks/case.schema.json",
  "title": "FixCost benchmark case",
  "description": "One diagnostic scenario. See benchmarks/SPEC.md section 2.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "vehicle", "complaint", "observations", "dtc_codes", "ground_truth", "tags"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^FC-[0-9]{4}$",
      "description": "Stable case id, e.g. FC-0042"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Bumped when a committed case is corrected (see CHANGELOG)."
    },
    "vehicle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["year", "make", "model", "powertrain", "mileage"],
      "properties": {
        "year": { "type": "integer", "minimum": 1980, "maximum": 2026 },
        "make": { "type": "string", "minLength": 1, "maxLength": 40 },
        "model": { "type": "string", "minLength": 1, "maxLength": 60 },
        "powertrain": { "type": "string", "enum": ["gas", "hybrid", "ev", "diesel"] },
        "mileage": { "type": "integer", "minimum": 0, "maximum": 500000 }
      }
    },
    "complaint": { "type": "string", "minLength": 1, "maxLength": 600 },
    "observations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 300 }
    },
    "dtc_codes": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[PBCU][0-9A-Fa-f]{4}$" },
      "description": "OBD-II codes; empty array if none."
    },
    "ground_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_diagnosis",
        "acceptable_diagnoses",
        "wrong_but_plausible",
        "must_mention_safety",
        "expected_cost_range_usd",
        "severity"
      ],
      "properties": {
        "primary_diagnosis": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "acceptable_diagnoses": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
        },
        "wrong_but_plausible": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
        },
        "must_mention_safety": { "type": "boolean" },
        "expected_cost_range_usd": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "integer", "minimum": 0, "maximum": 100000 }
        },
        "severity": { "type": "string", "enum": ["info", "moderate", "urgent", "do_not_drive"] }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 40 }
    }
  }
}
