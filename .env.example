# Copy this file to .env.local for local dev, or add these as Environment Variables in Vercel project settings.
# Never commit .env.local to git.

# Required: Anthropic API key for the /api/generate Edge Function.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default Anthropic model.
# Defaults to claude-sonnet-4-20250514 if unset.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: Sentry DSN for error tracking. Sign up free at https://sentry.io
# Leave empty to disable error tracking.
VITE_SENTRY_DSN=

# Optional: Plausible Analytics or any other domain for client-side analytics.
# VITE_ANALYTICS_DOMAIN=fixcost.ai
